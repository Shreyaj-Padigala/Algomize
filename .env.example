# =============================================
# Algomize - AI Crypto Trading Bot Configuration
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----- Server -----
PORT=3000
NODE_ENV=development

# ----- JWT Authentication -----
JWT_SECRET=your_jwt_secret_here_change_this
JWT_EXPIRES_IN=24h

# ----- PostgreSQL Database -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=algomize
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# ----- BloFin Exchange API (USDT-M Perpetual Futures) -----
# Get your API credentials from https://blofin.com
# Ensure your API key has trading permissions enabled
BLOFIN_API_KEY=your_blofin_api_key_here
BLOFIN_API_SECRET=your_blofin_api_secret_here
BLOFIN_PASSPHRASE=your_blofin_passphrase_here
BLOFIN_BASE_URL=https://openapi.blofin.com
BLOFIN_WS_URL=wss://openapi.blofin.com/ws/public

# ----- Groq AI -----
# Get your free API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ----- ElevenLabs Voice AI (Optional) -----
# Get your API key from https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ----- Trading Configuration -----
TRADING_SYMBOL=BTC-USDT
MAX_PORTFOLIO_PERCENT=50
SESSION_DURATION_HOURS=12

# ----- Logging -----
LOG_LEVEL=info
CSV_LOG_DIR=./csv_logs
