{
  "name": "algomize",
  "version": "1.0.0",
  "description": "AI Agent-Based Crypto Trading Bot for BTC/USDT on BloFin",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "db:migrate": "node src/db/migrate.js",
    "swagger": "node src/config/swagger.js"
  },
  "keywords": ["crypto", "trading", "bot", "blofin", "btc"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.12.0",
    "socket.io": "^4.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "axios": "^1.7.2",
    "ws": "^8.17.0",
    "csv-writer": "^1.6.0",
    "csv-parser": "^3.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.3.1",
    "@google/generative-ai": "^0.12.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage"
  }
}
